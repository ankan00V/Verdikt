# NVIDIA NIM API Key for Llama 3.1 405b
# Get this from: https://build.nvidia.com/explore/discover
NVIDIA_NIM_API_KEY="your_nvidia_nim_api_key_here"

# Tavily API Key for Web & News Search
# Get this from: https://tavily.com/
TAVILY_API_KEY="your_tavily_api_key_here"

# Financial Modeling Prep (FMP) API Key
# Get this from: https://site.financialmodelingprep.com/
FMP_API_KEY="your_financial_modeling_prep_api_key_here"

# Development only: replay saved API responses instead of burning real quota
# Do not set to true in production.
# USE_MOCK_DATA=false

# Upstash Serverless Redis (for caching API/LLM responses)
# Get this from: https://upstash.com/
UPSTASH_REDIS_REST_URL="your_upstash_redis_url_here"
UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_token_here"

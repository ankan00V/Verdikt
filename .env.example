# =============================================================================
# Verdikt — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# See README.md for where to get each key.
# =============================================================================

# REQUIRED — NVIDIA NIM API Key (for LLM inference via meta/llama-3.3-70b-instruct)
# Get it from: https://integrate.api.nvidia.com → Account → API Keys
NVIDIA_NIM_API_KEY=your_nvidia_nim_key_here

# OPTIONAL — Second NVIDIA NIM API Key (used as fallback during retries)
NVIDIA_FALLBACK_API_KEY=your_second_nvidia_nim_key_here

# REQUIRED — Tavily API Key (for news and web research)
# Get it from: https://tavily.com → Sign up → API Key
TAVILY_API_KEY=your_tavily_key_here

# OPTIONAL — Upstash Redis (for persistent checkpointing on Vercel)
# Get it from: https://upstash.com → Create Database → REST API
# Not needed for local development, only for Vercel deployment
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OPTIONAL — Yahoo Finance Proxy (needed on Vercel to bypass IP blocks)
# Get free proxies from: https://webshare.io → Proxy List
# Format: http://username:password@ip:port
YAHOO_PROXY_URL=

# DEV ONLY — Set to "true" to use mock data (avoids burning API credits)
USE_MOCK_DATA=false
